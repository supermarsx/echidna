# Orchestration scaffolding (session coordination — never committed)
/.orchestration

# Native build output
/native/dsp/build
/build

# Android app module build output + Gradle caches
/android/app/app/build
/android/app/.gradle
# Build-time generated assets (staged copies — never committed):
#   generated/echidna/assets      — flashable Magisk module zip (stageEngineModuleAsset)
#   generated/echidna/labJniLibs  — in-process DSP engine .so (stageLabDspJniLibs)
#   generated/echidna/helpAssets  — repository docs mirrored for the in-app Help (stageHelpDocs)
# All live under the already-ignored build/ tree; listed explicitly for clarity.
/android/app/app/build/generated/echidna/

# Control-service module build output + native (.cxx) intermediates
/android/control-service/service/build
/android/control-service/service/.cxx

# LSPosed shim build output + Gradle cache
/android/lsposed-shim/shim/build
/android/lsposed-shim/.gradle

# Generic build-output safety nets (any subproject)
.gradle/
**/.cxx/
local.properties
__pycache__/
*.pyc

# Release signing material — NEVER commit real keystores or their passwords.
# (keystore.properties.example is the committed placeholder template.)
keystore.properties
**/keystore.properties
*.jks
*.keystore

# Magisk module build output (default ECHIDNA_OUT_DIR of tools/build_magisk_module.sh)
/out/

# MkDocs build output (generated by `mkdocs build`)
/site/

# Built binary artifacts — defense-in-depth (no such binaries are tracked)
*.apk
*.so
*.aar
/android/app/interception-probe/build
