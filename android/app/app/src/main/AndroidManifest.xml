<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.echidna.app">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- The Lab tab records the device's OWN microphone to test the mic and run the
         local DSP engine on the user's own voice. It captures only in-app while the
         user is on the Lab screen; it does NOT intercept any other app's audio. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Control service now ships inside this APK; the old cross-package
         signature permission is self-referential and has been removed. -->

    <!-- Android 11+ (targetSdk 34) package-visibility filtering: the whitelist
         editor enumerates launchable apps via queryIntentActivities(MAIN/LAUNCHER),
         which only returns visible packages without this declaration. Scoped to
         launcher activities rather than QUERY_ALL_PACKAGES (Play-policy-hostile). -->
    <queries>
        <!-- The policy provider must resolve the headless LSPosed shim package to pin its
             UID/signing identity. It has no launcher activity, so the intent query below does
             not make it visible on Android 11+. -->
        <package android:name="com.echidna.lsposed" />
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>


    <application
        android:name=".EchidnaApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="Echidna"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Echidna">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Echidna">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".system.EchidnaQuickSettingsTileService"
            android:exported="false"
            android:icon="@drawable/ic_echidna_mono"
            android:label="Echidna"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <receiver
            android:name=".system.EchidnaWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- Compact control widget: master toggle + panic + honest status. -->
        <receiver
            android:name=".system.EchidnaControlWidgetProvider"
            android:exported="false"
            android:label="@string/widget_control_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_control_info" />
        </receiver>

        <!-- Preset widget: active preset + cycle. -->
        <receiver
            android:name=".system.EchidnaPresetWidgetProvider"
            android:exported="false"
            android:label="@string/widget_preset_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_preset_info" />
        </receiver>

        <!-- Large hub widget: status + preset + quick toggles. -->
        <receiver
            android:name=".system.EchidnaQuickControlsWidgetProvider"
            android:exported="false"
            android:label="@string/widget_quick_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_quick_info" />
        </receiver>

        <receiver
            android:name=".system.EchidnaNotificationReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.echidna.app.action.TOGGLE_ENGINE" />
                <action android:name="com.echidna.app.action.CYCLE_PRESET" />
                <action android:name="com.echidna.app.action.OPEN_APP" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".system.EchidnaBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- In-APK control service (from the :service library). Bound by
             ControlServiceClient via ComponentName; not exported (single-APK). -->
        <service
            android:name="com.echidna.control.service.EchidnaControlService"
            android:exported="false" />
    </application>

</manifest>
