<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header: status dot + title + honest status label + open-app -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/quickStatusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/widget_quick_label"
            android:src="@drawable/widget_dot" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/widget_on_surface"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/quickStatusLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Standby"
            android:textColor="@color/widget_on_surface_variant"
            android:textSize="12sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/quickOpen"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/widget_btn"
            android:clickable="true"
            android:contentDescription="@string/widget_open_app"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_widget_launch" />
    </LinearLayout>

    <!-- Preset row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:letterSpacing="0.1"
            android:text="@string/widget_preset_heading"
            android:textAllCaps="true"
            android:textColor="@color/widget_on_surface_variant"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/quickPresetName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/app_name"
            android:textColor="@color/widget_on_surface"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/quickPresetPrev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_btn"
            android:clickable="true"
            android:contentDescription="@string/widget_prev_preset"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_widget_chevron_left" />

        <ImageView
            android:id="@+id/quickPresetNext"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_btn"
            android:clickable="true"
            android:contentDescription="@string/widget_next_preset"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/ic_widget_chevron_right" />
    </LinearLayout>

    <!-- Quick toggles: master / bypass / sidetone / panic -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/quickMaster"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/widget_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minHeight="40dp"
            android:text="@string/widget_master"
            android:textColor="@color/widget_on_surface"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/quickBypass"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minHeight="40dp"
            android:text="@string/widget_bypass"
            android:textColor="@color/widget_on_surface"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/quickSidetone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minHeight="40dp"
            android:text="@string/widget_sidetone"
            android:textColor="@color/widget_on_surface"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/quickPanic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_panic"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minHeight="40dp"
            android:text="@string/widget_panic"
            android:textColor="#FFEF5350"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
