<resources>
    <!-- Material You (Android 12+) light: pull the wallpaper-derived system palette so the
         widgets tint themselves to the user's theme, consistent with Material3 dynamic colour. -->
    <color name="widget_surface">@android:color/system_neutral1_50</color>
    <color name="widget_surface_variant">@android:color/system_neutral2_100</color>
    <color name="widget_on_surface">@android:color/system_neutral1_900</color>
    <color name="widget_on_surface_variant">@android:color/system_neutral2_700</color>
    <color name="widget_accent">@android:color/system_accent1_600</color>
    <color name="widget_on_accent">@android:color/system_accent1_0</color>
    <color name="widget_outline">@android:color/system_neutral2_400</color>
</resources>
