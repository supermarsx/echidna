# Release signing configuration for the Echidna companion app.
#
# Copy this file to `keystore.properties` (same directory) and fill in the real
# values. `keystore.properties` and all `*.jks` / `*.keystore` files are
# git-ignored — NEVER commit a real keystore or its passwords.
#
# The app module (android/app/app/build.gradle.kts) reads these keys when present.
# If this file is absent, the release build falls back to debug signing so local
# and CI builds without secrets still succeed (producing a non-distributable APK).
#
# In CI, prefer supplying these as secrets via environment variables / Gradle
# properties instead of a checked-in file:
#   RELEASE_STORE_FILE, RELEASE_STORE_PASSWORD, RELEASE_KEY_ALIAS, RELEASE_KEY_PASSWORD
#
# Generate a keystore (example):
#   keytool -genkeypair -v -keystore echidna-release.jks -alias echidna \
#           -keyalg RSA -keysize 4096 -validity 10000

# Path to the keystore file. Absolute, or relative to android/app/.
storeFile=echidna-release.jks

# Password protecting the keystore file.
storePassword=CHANGE_ME

# Alias of the key entry to sign with.
keyAlias=echidna

# Password protecting the key entry (often the same as storePassword).
keyPassword=CHANGE_ME
