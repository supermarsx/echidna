<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!-- Debug-only, shell-readable checkpoint surface for the disposable AVD session proof.
             The release variant contains neither this provider nor this authority. -->
        <provider
            android:name=".service.SessionProofEvidenceProvider"
            android:authorities="com.echidna.app.sessionproof"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" />
    </application>

</manifest>
