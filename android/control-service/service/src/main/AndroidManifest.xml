<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- The control service now ships inside the companion APK (com.echidna.app).
         It is bound in-process by ControlServiceClient, so it is not exported and
         no longer needs the self-referential signature permission. The hosting
         app manifest also declares this component; the merged result is consistent. -->
    <application>
        <service
            android:name=".service.EchidnaControlService"
            android:enabled="true"
            android:exported="false" />
        <!-- Explicit read-only endpoint for target-UID-scoped LSPosed policy. The privileged
             control service above remains private to the companion APK. -->
        <service
            android:name=".service.PolicySnapshotService"
            android:enabled="true"
            android:exported="true" />
    </application>
</manifest>
